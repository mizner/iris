{
  "name": "@mizner/iris-omp",
  "version": "4.8.0",
  "description": "Oh My Pi (OMP) extension adapter for Iris browser automation.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizner/iris.git",
    "directory": "packages/omp"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/extension.ts --target=node --outfile=dist/extension.js",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "omp": {
    "extensions": [
      "./dist/extension.js"
    ]
  },
  "devDependencies": {
    "@mizner/iris-opencode": "workspace:*"
  }
}
