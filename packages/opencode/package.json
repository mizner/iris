{
  "name": "@mizner/iris-opencode",
  "version": "4.8.1",
  "description": "OpenCode adapter for Iris browser automation.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizner/iris.git",
    "directory": "packages/opencode"
  },
  "main": "./dist/plugin.js",
  "exports": {
    ".": "./dist/plugin.js",
    "./plugin": "./dist/plugin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/plugin.ts --target=node --outfile=dist/plugin.js",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "dependencies": {
    "agent-browser": "^0.4.0"
  },
  "devDependencies": {
    "@mizner/iris": "workspace:*",
    "@opencode-ai/plugin": "*",
    "bun-types": "*"
  }
}
