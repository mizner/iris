{
  "name": "iris-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "version": "4.7.0",
  "description": "Open-source Chrome extension and local browser automation runtime for OpenCode.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "bun run --cwd packages/opencode build && bun run --cwd packages/mcp build",
    "check:extension": "node --check packages/core/extension/background.js",
    "check:runtime": "node --check packages/core/bin/broker.cjs packages/core/bin/browser-cli.cjs packages/core/bin/cli.js packages/core/bin/native-host.cjs packages/core/extension/background.js",
    "prepublishOnly": "bun run build",
    "test": "node --test packages/core/test/",
    "runtime:install": "node packages/core/bin/cli.js install",
    "runtime:migrate": "node packages/core/bin/cli.js migrate",
    "runtime:update": "node packages/core/bin/cli.js update",
    "uninstall": "node packages/core/bin/cli.js uninstall",
    "status": "node packages/core/bin/cli.js status",
    "tool-test": "bun bin/tool-test.ts"
  },
  "keywords": [
    "opencode",
    "browser",
    "automation",
    "chrome",
    "plugin",
    "native-messaging"
  ],
  "author": "Michael Mizner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizner/iris.git"
  },
  "bugs": {
    "url": "https://github.com/mizner/iris/issues"
  },
  "homepage": "https://github.com/mizner/iris#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "dependencies": {
    "agent-browser": "^0.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "*",
    "bun-types": "*"
  }
}
